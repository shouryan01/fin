{
	"name": "fin",
	"version": "1.0.0",
	"description": "Offline-only, privacy-focused personal finance tracker",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"go": "concurrently --kill-others --success first \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"check": "biome check --write",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@t3-oss/env-core": "^0.13.10",
		"@tanstack/react-form": "^1.28.3",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "^1.163.3",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/router-plugin": "^1.164.0",
		"better-sqlite3": "^12.6.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"electrobun": "1.14.4",
		"lucide-react": "^0.576.0",
		"radix-ui": "^1.4.3",
		"react": "^19",
		"react-dom": "^19",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/bun": "latest",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.1.0",
		"dotenv": "^17.3.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
